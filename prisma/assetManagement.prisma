

// ========== ASSET TYPES ==========
enum AssetType {
  BANK_ACCOUNT
  INVESTMENT_ACCOUNT
  BUSINESS_INTEREST
  RETIREMENT_ACCOUNT
  INSURANCE_PLAN
  SAFE_DEPOSIT_BOX
  CRYPTO
}

enum LoanType {
  OUTSTANDING // user owes someone
  GIVEN // someone owes user
}

enum CoverType {
  TERM_LIFE
  WHOLE_LIFE
  ENDOWMENT
  UNIVERSAL_LIFE
  INVESTMENT
  OTHER
}

model Asset {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  type             AssetType // e.g. for bank account: "Savings", "Checking"; for business: "LLC", "Partnership"
  // Common fields
  isJointlyOwned   Boolean   @default(false)
  isNominated      Boolean   @default(false)
  approximateValue Float? // in dollars (can be null for some types)
  description      String? // used for SafeDepositBox, Crypto

  // Bank & Investment & Retirement
  institutionName String?
  accountNumber   String?

  // Business
  companyName String?

  // Insurance
  policyNumber String?
  coverType    CoverType?
  maturityDate DateTime?
  faceValue    Float?

  // Crypto / Safe box description already used

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("assets")
}

enum PropertyType {
  RESIDENTIAL
  COMMERCIAL
  LAND
  OTHER
}

model Property {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  userId          String       @db.ObjectId
  type            PropertyType
  country         String
  streetAddress   String
  unitNumber      String?
  postcode        String?
  isJointProperty Boolean      @default(false)
  estimatedValue  Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("properties")
}

model Loan {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @db.ObjectId
  type               LoanType // OUTSTANDING (I owe) or GIVEN (someone owes me)
  institutionName   String // name of person/business
  accountNumber     String // account number
  approximateBalance Float
  


  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("loans")
}

model Advisor {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("advisors")
}
