enum ExecutorType {
  PRIMARY
  SECONDARY
}

enum DistributionType {
  PERCENTAGE
  SPECIFIC_GIFT
  RESIDUARY
  CHARITY
}
enum WillStatus {
  DRAFT
  COMPLETED
  EXECUTED
  REVOKED
}

model Will {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  userId          String     @db.ObjectId
  status          WillStatus @default(DRAFT)
  completedSteps  String[]
  currentStep     Int        @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                  @relation(fields: [userId], references: [id])
  executors             Executor[]
  estateDistributions   EstateDistribution[]
  willGifts             WillGift[]
  petCaretakers         PetCaretaker[]
  



  @@unique([userId])
  @@map("wills")
}

model Executor {
  id              String       @id @default(auto()) @map("_id") @db.ObjectId
  willId          String       @db.ObjectId
  peopleId        String?       @db.ObjectId
  executorType    ExecutorType?
  backupPeopleId  String?      @db.ObjectId
  order           Int          @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  will         Will    @relation(fields: [willId], references: [id])
  person       People?  @relation(name: "ExecutorMainPerson", fields: [peopleId], references: [id])
  backupPerson People? @relation(name: "ExecutorBackupPerson", fields: [backupPeopleId], references: [id])

  @@index([willId])
  @@map("executors")
}

