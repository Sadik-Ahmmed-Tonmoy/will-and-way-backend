model EstateDistribution {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  willId          String           @db.ObjectId
  peopleId        String?          @db.ObjectId
  charityName     String?
  charityUEN      String?
  percentage      Float
  distributionType DistributionType
  order           Int              @default(1)
  notes           String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  will            Will                      @relation(fields: [willId], references: [id])
  person          People?                   @relation(name: "DistributionPerson", fields: [peopleId], references: [id])
  backupDistributors BackupDistributor[]
  
  @@index([willId])
  @@map("estate_distributions")
}

model BackupDistributor {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  distributionId        String   @db.ObjectId
  peopleId              String?  @db.ObjectId
  charityName           String?
  charityUEN            String?
  order                 Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  distribution          EstateDistribution @relation(fields: [distributionId], references: [id])
  person                People?            @relation(name: "BackupDistributorPerson", fields: [peopleId], references: [id])

  @@index([distributionId])
  @@map("backup_distributors")
}

model WillGift {
  id      String @id @default(auto()) @map("_id") @db.ObjectId
  willId  String @db.ObjectId
  giftId  String @db.ObjectId
  order   Int    @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  will  Will  @relation(fields: [willId], references: [id])
  gift  Gift  @relation(fields: [giftId], references: [id])

  @@index([willId])
  @@index([giftId])
  @@map("will_gifts")
}

model PetCaretaker {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  willId          String   @db.ObjectId
  petId           String   @db.ObjectId
  caretakerId     String   @db.ObjectId
  cashAllocation  Float?
  notes           String?
  order           Int      @default(1)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  will      Will   @relation(fields: [willId], references: [id])
  pet       People @relation(name: "CaretakerPet", fields: [petId], references: [id])
  caretaker People @relation(name: "CaretakerPerson", fields: [caretakerId], references: [id])

  @@index([willId])
  @@map("pet_caretakers")
}