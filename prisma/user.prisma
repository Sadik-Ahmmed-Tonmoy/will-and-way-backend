// ========== ENUMS (keep all your existing enums) ==========

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum LogInProcess {
  EMAIL
  PHONE
  GOOGLE
  APPLE
}

enum SubscriptionTier {
  FREE
  PREMIUM
}

enum OTPPurpose {
  EMAIL_VERIFICATION
  PHONE_VERIFICATION
  PASSWORD_RESET
}

enum maritalStatus {
  SINGLE
  MARRIED
  LONG_TERM_PARTNER
}

enum TypeOfIdentifier {
  NRIC_OR_FIN
  PASSPORT
  FOREIGN_ID
}

enum RelationType {
  FRIEND
  SISTER
  BROTHER
  COUSIN
  FATHER
  MOTHER
  SIBLING
  GRANDPARENT
  PARENT
  NEPHEW
  OTHER
  SPOUSE
  PARTNER
  CHILD
  PET
}

enum Religion {
  CHRISTIAN
  BUDDHIST
  MUSLIM
  HINDU
  JEWISH
  SIKH
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
  LONG_TERM_PARTNER
}

enum Region {
  SINGAPORE
  INDIA
  UNITED_STATES
}

// ========== MODELS ==========

model User {
  id                 String         @id @default(auto()) @map("_id") @db.ObjectId
  fullName           String?
  nickname           String?        @unique
  email              String?        @unique
  phoneNumber        String?
  password           String?
  profileImage       String?
  region             Region?
  religion           Religion?
  maritalStatus      MaritalStatus?
  role               UserRole       @default(USER)
  status             UserStatus     @default(ACTIVE)
  logInProcess       LogInProcess
  isVerified         Boolean        @default(false)
  isEmailVerified    Boolean        @default(false)
  isPhoneVerified    Boolean        @default(false)
  fcmToken           String?
  isProfileCompleted Boolean        @default(false)

  subscriptionTier      SubscriptionTier @default(FREE)
  subscriptionExpiresAt DateTime?

  people   People[]
  gifts    Gift[]
  messages Message[]
  otps     OTP[]
  addresses Address[]
  assets    Asset[]
  properties Property[]
  loans     Loan[]
  advisors  Advisor[]
  wills     Will[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OTP {
  id        String     @id @default(auto()) @map("_id") @db.ObjectId
  email     String?
  phone     String?
  code      String
  purpose   OTPPurpose
  userId    String     @db.ObjectId
  user      User       @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime   @default(now())
  used      Boolean    @default(false)

  @@index([userId, purpose])
  @@index([email, code])
  @@index([phone, code])
  @@map("otps")
}

model Address {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  country        String
  streetAddress  String
  unitNumber     String
  postCode       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model People {
  id                 String            @id @default(auto()) @map("_id") @db.ObjectId
  userId             String            @db.ObjectId
  fullName           String
  email              String?
  typeOfIdentifier   TypeOfIdentifier?
  identifierValue    String?
  dateOfBirth        DateTime?
  relationWithUser   RelationType?
  governmentIssuedId Boolean?          @default(false)
  relationType       RelationType

  // 🔥 FIX: Add matching @relation attribute to giftRecipients 🔥
  giftRecipients         GiftRecipient[]      @relation("GiftRecipientPerson")
  executorAsMain         Executor[]           @relation("ExecutorMainPerson")
  executorAsBackup       Executor[]           @relation("ExecutorBackupPerson")
  estateDistributions    EstateDistribution[] @relation("DistributionPerson")
  petAsPet               PetCaretaker[]       @relation("CaretakerPet")
  petAsCaretaker         PetCaretaker[]       @relation("CaretakerPerson")
    // Add these opposite relations for backup distributors
  backupDistributors     BackupDistributor[]  @relation("BackupDistributorPerson")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}